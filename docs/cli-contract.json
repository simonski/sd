    {"name": "count", "kind": "builtin"},
    {"name": "checkpoint", "kind": "builtin"},
    {"name": "doctor", "kind": "builtin"},
    {"name": "spec", "kind": "builtin"},
    {"name": "help", "kind": "builtin"},
    {"name": "version", "kind": "builtin"}
